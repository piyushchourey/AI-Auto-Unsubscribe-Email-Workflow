# LLM Configuration
LLM_PROVIDER=ollama  # Options: ollama, gemini
OLLAMA_MODEL=llama2  # For local Ollama
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Brevo Configuration
BREVO_API_KEY=your_brevo_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# IMAP Configuration
IMAP_ENABLED=true

# Email Provider: outlook, gmail, rediff, yahoo, custom
IMAP_PROVIDER=outlook

# Email Credentials
IMAP_EMAIL=your_email@outlook.com
IMAP_PASSWORD=your_password_or_app_password

# Advanced Settings (optional - provider defaults used if not set)
# IMAP_HOST=imap.rediffmail.com  # Only needed for custom provider
# IMAP_PORT=993  # Default: 993 for SSL

# Worker Settings
IMAP_CHECK_INTERVAL=3600  # Check every hour (in seconds)
IMAP_FOLDER=INBOX  # Folder to monitor

# Auth (required for protected unsubscribe/blocklist/worker endpoints)
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOGIN_RATE_LIMIT_PER_MINUTE=5
# Seed first admin user on startup (only if no users exist)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=your_secure_password
